{
  "expo": {
    "name": "Girassóis+",
    "slug": "autismcad",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "autismcad",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "icon": "./store-assets/icon/icon-1024.png",
    "android": {
      "package": "com.autismcad.app",
      "adaptiveIcon": {
        "foregroundImage": "./store-assets/icon/adaptive-foreground-1024.png",
        "backgroundColor": "#0e1626"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.autismcad.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "extra": {
      "apiBaseUrl": "https://www.girassois.com.br",
      "router": {},
      "eas": {
        "projectId": "8b6d05e5-c9a9-46d0-b97a-895778765a02"
      }
    },
    "owner": "netface"
  }
}
