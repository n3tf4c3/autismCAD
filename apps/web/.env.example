NODE_ENV=development
NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=change_me_with_a_long_random_secret
# Opcional: alias aceito pelo NextAuth/Vercel (mesmo valor do AUTH_SECRET)
NEXTAUTH_SECRET=

# PostgreSQL + Drizzle
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/autismcad
# Opcional (Neon): URL sem "-pooler" para uso com DATABASE_DRIVER=neon-serverless.
DATABASE_URL_UNPOOLED=
DATABASE_DRIVER=neon-serverless
REQUIRE_DB_TRANSACTIONS=1
APP_TIMEZONE=America/Sao_Paulo

# Password hashing
BCRYPT_COST=12

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Optional: Cloudflare dashboard "Token value" (not required for S3 SDK usage)
R2_API_TOKEN=
R2_BUCKET=
R2_REGION=auto
R2_ENDPOINT=
R2_PUBLIC_BASE_URL=
CRON_SECRET=
R2_TEMP_UPLOAD_RETENTION_HOURS=24
R2_TEMP_UPLOAD_CLEANUP_BATCH_SIZE=500
