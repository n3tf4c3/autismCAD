{
  "name": "autismcad-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.7.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "npm run db:generate -w @autismcad/db",
    "db:migrate": "npm run db:migrate -w @autismcad/db",
    "db:check": "npm run db:check -w @autismcad/db",
    "db:push": "npm run db:push -w @autismcad/db",
    "db:studio": "npm run db:studio -w @autismcad/db",
    "db:seed:admin": "npm run db:seed:admin -w @autismcad/web",
    "db:cleanup:evolucao": "npm run db:cleanup:evolucao -w @autismcad/web",
    "db:cleanup:anamnese": "npm run db:cleanup:anamnese -w @autismcad/web",
    "db:cleanup:plano-ensino": "npm run db:cleanup:plano-ensino -w @autismcad/web"
  },
  "devDependencies": {
    "turbo": "^2"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "esbuild": "^0.28.1",
    "uuid": "^11.1.1"
  }
}
