{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "NODE_ENV",
    "NEXTAUTH_URL",
    "NEXTAUTH_SECRET",
    "AUTH_SECRET",
    "DATABASE_URL",
    "DATABASE_URL_UNPOOLED",
    "DATABASE_DRIVER",
    "REQUIRE_DB_TRANSACTIONS",
    "APP_TIMEZONE",
    "BCRYPT_COST",
    "R2_ACCOUNT_ID",
    "R2_ACCESS_KEY_ID",
    "R2_SECRET_ACCESS_KEY",
    "R2_API_TOKEN",
    "R2_BUCKET",
    "R2_REGION",
    "R2_ENDPOINT",
    "R2_PUBLIC_BASE_URL",
    "CRON_SECRET",
    "R2_TEMP_UPLOAD_RETENTION_HOURS",
    "R2_TEMP_UPLOAD_CLEANUP_BATCH_SIZE"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
